{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gradus Renamer",
  "version": "1.0.1",
  "identifier": "com.gradus.renamer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gradus Renamer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFREE5MTA3RkI5Mjg3NTcKUldSWGg1TDdCNUhhWHNpWTdvbTFFTTc0UiszQ2U4KzBHbkJzUDlsVDF1Qnl2QTNOQ1dqNHpza0YK",
      "endpoints": [
        "https://github.com/ymgraphics/gradus-renamer/releases/latest/download/latest.json"
      ]
    }
  }
}
